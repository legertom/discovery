# Neon Postgres connection string (from the Neon dashboard or Vercel's Neon integration).
# Use the POOLED connection string. Example:
# postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Vercel AI Gateway API key (https://vercel.com/dashboard → AI Gateway → API Keys).
# Needed for the "Import from interview" feature. On Vercel, the Gateway can use
# OIDC automatically and this can be omitted.
AI_GATEWAY_API_KEY=
